# Microsoft Fabric SQL Warehouse Connection
# Get these from Fabric Portal > Your Warehouse > Settings > SQL connection string
FABRIC_SERVER=
FABRIC_DATABASE=

# Leave both EMPTY to use local SQLite (for development without Fabric access)
# Example:
#   FABRIC_SERVER=xxxxxxxxxxxx.datawarehouse.fabric.microsoft.com
#   FABRIC_DATABASE=MyWarehouse

# Authentication: Uses DefaultAzureCredential (picks up 'az login' session automatically)
# No explicit credentials needed — just run 'az login' before starting the backend.
